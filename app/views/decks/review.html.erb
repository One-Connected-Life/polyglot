<% content_for :title, "Review #{@deck.name}" %>
<% target = current_user.target_language %>
<% source = current_user.source_language %>

<div class="mx-auto max-w-lg">
  <%= link_to "← decks", root_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
  <h1 class="mt-1 text-2xl font-semibold tracking-tight">Review “<%= @deck.name %>”</h1>
  <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
    <%= pluralize(@terms.size, "word") %> to review · imported <%= @deck.created_at.strftime("%b %-d, %Y at %-l:%M %p") %>
  </p>
  <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
    Uncheck anything you don't want, fix a translation if needed, then save —
    the rest becomes a drillable deck.
  </p>

  <%= form_with url: review_deck_path(@deck), method: :patch, class: "mt-6 space-y-2" do %>
    <% @terms.each do |term| %>
      <% tgt = term.translation(target); src = term.translation(source) %>
      <label class="flex items-start gap-3 rounded-lg border border-gray-200 bg-white p-3
                    has-[:checked]:border-gray-400 dark:border-gray-800 dark:bg-gray-900
                    dark:has-[:checked]:border-gray-600">
        <input type="checkbox" name="keep[]" value="<%= term.id %>" checked
               class="mt-2 size-4 shrink-0 accent-gray-900 dark:accent-gray-100" />
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2">
            <% if tgt&.article.present? %>
              <span class="text-sm text-gray-400"><%= tgt.article %></span>
            <% end %>
            <%= text_field_tag "terms[#{term.id}][target]", tgt&.text,
                  class: "min-w-0 flex-1 rounded border border-gray-200 bg-gray-50 px-2 py-1 text-sm
                          dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100" %>
            <span class="text-gray-400">—</span>
            <%= text_field_tag "terms[#{term.id}][source]", src&.text,
                  class: "min-w-0 flex-1 rounded border border-gray-200 bg-gray-50 px-2 py-1 text-sm
                          dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100" %>
          </div>
          <% if tgt&.ipa.present? || tgt&.etymology.present? %>
            <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
              <% if tgt.ipa.present? %><span class="font-mono">/<%= tgt.ipa %>/</span><% end %>
              <% if tgt.etymology.present? %><span><%= " · " if tgt.ipa.present? %><%= tgt.etymology %></span><% end %>
            </p>
          <% end %>
        </div>
      </label>
    <% end %>

    <div class="sticky bottom-0 bg-gradient-to-t from-white via-white pt-3 dark:from-gray-950 dark:via-gray-950">
      <button type="submit" class="<%= primary_button_classes %>">Save deck</button>
      <%= button_to "Discard", deck_path(@deck), method: :delete,
            class: "mt-2 w-full rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-600
                    hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-900",
            form: { data: { turbo_confirm: "Discard this deck and its words?" } } %>
    </div>
  <% end %>
</div>
