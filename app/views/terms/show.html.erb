<% nl = @term.translation("nl") %>
<% en = @term.translation("en") %>
<% content_for :title, (nl&.text || en&.text || "word") %>
<% meter = { "easy" => "● ○ ○", "medium" => "● ● ○", "hard" => "● ● ●" }[@term.difficulty.to_s] %>

<%= link_to "← decks", root_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>

<div class="mt-3 mb-10">
  <% if nl %>
    <div data-controller="speak" data-speak-text-value="<%= nl.with_article %>" data-speak-lang-value="nl">
      <div class="flex items-baseline gap-3">
        <p class="text-4xl font-semibold tracking-tight sm:text-5xl"><%= nl.with_article %></p>
        <button type="button" data-action="speak#say" aria-label="pronounce"
                class="rounded-md px-2 py-1 text-base text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-800 dark:hover:text-gray-200">🔊</button>
      </div>
      <p data-speak-target="hint" class="mt-2 hidden text-xs text-amber-700 dark:text-amber-300"></p>
    </div>
  <% end %>

  <% if en %>
    <div class="mt-3 flex items-baseline gap-2 text-gray-600 dark:text-gray-300">
      <p class="text-xl"><%= en.with_article %></p>
      <%= render "terms/speaker", text: en.with_article, lang: "en" %>
    </div>
  <% end %>

  <% if meter %>
    <p class="mt-4 text-[11px] tracking-wide text-gray-400"><%= meter %>&nbsp;&nbsp;<%= @term.difficulty %><span class="ml-1 text-gray-400">· vs English</span></p>
  <% end %>
</div>

<% others = (Translation::LANGUAGES.keys - Translation::SURFACED).filter_map { |code| [code, @term.translation(code)] if @term.translation(code) } %>
<% if others.any? %>
  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
    Other languages <span class="font-normal normal-case text-gray-400">— not yet verified</span>
  </p>
  <ul class="divide-y divide-gray-100 border-y border-gray-100 dark:divide-gray-800 dark:border-gray-800">
    <% others.each do |code, t| %>
      <li class="flex items-center justify-between py-2">
        <div class="flex items-baseline gap-3">
          <span class="w-6 text-[11px] uppercase text-gray-400"><%= code %></span>
          <span class="text-sm"><%= t.with_article %></span>
        </div>
        <%= render "terms/speaker", text: t.with_article, lang: code %>
      </li>
    <% end %>
  </ul>
<% end %>
