<% content_for :title, "#{current_user.target_language_name} drill" %>
<% target = current_user.target_language %>
<% source = current_user.source_language %>
<% learning = current_user.active_learning_languages %>
<% pending = @decks.select { |d| d.status == "pending" } %>

<% if pending.any? %>
  <% content_for :head do %><meta http-equiv="refresh" content="5"><% end %>
<% end %>

<header class="mb-10 flex items-end justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight"><%= current_user.target_language_name %> drill</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Your vocabulary, your pace.</p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "Your words →", stats_path, class: "shrink-0 text-xs text-gray-500 hover:underline dark:text-gray-400" %>
    <%= link_to "Settings", onboarding_path, class: "shrink-0 text-xs text-gray-500 hover:underline dark:text-gray-400" %>
  </div>
</header>

<% if pending.any? %>
  <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
    ⏳ Generating <%= pending.map(&:name).to_sentence %>… this page refreshes itself.
  </div>
<% end %>

<% failed = @decks.select { |d| d.status == "failed" } %>
<% if failed.any? %>
  <div class="mb-6 rounded-lg border border-rose-300 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-300">
    <p>Couldn't build <%= failed.map(&:name).to_sentence %> — the word generator errored. Try
      <%= link_to "a different topic", new_deck_path, class: "underline" %>.</p>
    <div class="mt-2 flex flex-wrap gap-2">
      <% failed.each do |d| %>
        <%= button_to "Remove #{d.name}", deck_path(d), method: :delete,
              class: "rounded border border-rose-300 px-2 py-0.5 text-xs hover:bg-rose-100 dark:border-rose-700 dark:hover:bg-rose-900/40" %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @word_count.zero? && pending.none? %>
  <div class="rounded-lg border border-gray-300 bg-white px-5 py-6 text-center dark:border-gray-700 dark:bg-gray-900">
    <p class="text-sm text-gray-600 dark:text-gray-300">No words yet.</p>
    <p class="mx-auto mt-1 max-w-sm text-xs text-gray-500 dark:text-gray-400">
      Pick a topic and we'll build a <%= current_user.target_language_name %> deck for you.
    </p>
    <%= link_to "Create your first deck", new_deck_path,
          class: "mt-5 inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
  </div>
<% elsif @word_count.positive? %>
  <% if @miss_counts.any? %>
    <div class="mb-4 flex items-center justify-between gap-4 rounded-lg border border-gray-200 border-l-4 border-l-rose-400 bg-white px-4 py-4 dark:border-gray-700 dark:border-l-rose-400 dark:bg-gray-900">
      <div>
        <span class="text-base font-semibold">Your misses</span>
        <p class="text-xs text-gray-500 dark:text-gray-400">words you got wrong last time — get them right to clear them</p>
      </div>
      <div class="flex items-center gap-2 text-xs">
        <% @miss_counts.each do |(from, to), count| %>
          <%= link_to "#{from.upcase} → #{to.upcase} (#{count})", play_path(deck: "misses", from: from, to: to),
                class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── All words row: single-language + optional multi-language ── %>
  <div class="mb-8 flex items-center justify-between gap-4 rounded-lg border border-gray-300 bg-white px-4 py-4 dark:border-gray-700 dark:bg-gray-900">
    <div>
      <%= link_to "All words", play_path(deck: "all", from: source, to: target), class: "text-base font-semibold hover:underline" %>
      <p class="text-xs text-gray-500 dark:text-gray-400">every word, shuffled · <%= pluralize(@word_count, "word") %></p>
    </div>
    <div class="flex flex-wrap items-center justify-end gap-2 text-xs">
      <%= link_to "#{source.upcase} → #{target.upcase}", play_path(deck: "all", from: source, to: target),
            class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
      <%= link_to "#{target.upcase} → #{source.upcase}", play_path(deck: "all", from: target, to: source),
            class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
      <%# Multi-language entry point: only shown when the user has 2+ learning languages %>
      <% if current_user.multi_language_drill? %>
        <%= link_to "#{source.upcase} → all #{learning.size}", play_path(deck: "all", from: source, multi: "1"),
              class: "rounded-md border border-gray-900 bg-gray-900 px-2.5 py-1 text-white hover:bg-gray-700 dark:border-gray-100 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
      <% end %>
    </div>
  </div>

  <div class="mb-3 flex items-center justify-between">
    <p class="text-xs uppercase tracking-wide text-gray-400">your decks</p>
    <%= link_to "+ add a topic", new_deck_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
  </div>

  <ul class="divide-y divide-gray-200 border-y border-gray-200 dark:divide-gray-800 dark:border-gray-800">
    <% @decks.each do |deck| %>
      <% next unless deck.status != "pending" && deck.terms.any? %>
      <li class="flex items-center justify-between gap-4 py-4">
        <div>
          <%= link_to deck.name, play_path(deck: deck.slug, from: source, to: target), class: "text-base font-medium hover:underline" %>
          <% unit = deck.terms.exists?(kind: "sentence") ? "sentence" : "word" %>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= pluralize(deck.terms.size, unit) %><%= " · #{deck.topic}" if deck.topic.present? %></p>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-2 text-xs">
          <%= link_to "#{source.upcase} → #{target.upcase}", play_path(deck: deck.slug, from: source, to: target),
                class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
          <%= link_to "#{target.upcase} → #{source.upcase}", play_path(deck: deck.slug, from: target, to: source),
                class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
          <% if current_user.multi_language_drill? %>
            <%= link_to "#{source.upcase} → all #{learning.size}", play_path(deck: deck.slug, from: source, multi: "1"),
                  class: "rounded-md border border-gray-900 bg-gray-900 px-2.5 py-1 text-white hover:bg-gray-700 dark:border-gray-100 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>
