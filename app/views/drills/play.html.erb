<% content_for :title, "#{@title} — drill" %>

<% if @cards.empty? %>
  <p class="text-sm text-gray-500 dark:text-gray-400">
    No <%= Translation::LANGUAGES[@from] %> → <%= Translation::LANGUAGES[@to] %> pairs in this deck yet.
    <%= link_to "Back to decks", root_path, class: "underline" %>
  </p>
<% else %>
  <div data-controller="drill"
       data-drill-cards-value="<%= @cards.to_json %>"
       data-drill-from-value="<%= @from %>"
       data-drill-to-value="<%= @to %>"
       data-drill-record-url-value="<%= attempts_path %>">
    <header class="mb-6 flex items-start justify-between">
      <div>
        <%= link_to "← decks", root_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
        <h1 class="mt-1 text-lg font-semibold"><%= @title %></h1>
      </div>
      <div class="text-right text-xs text-gray-500 dark:text-gray-400">
        <div><%= Translation::LANGUAGES[@from] %> → <%= Translation::LANGUAGES[@to] %></div>
        <%= link_to "⇄ swap", play_path(deck: @deck_slug, from: @to, to: @from), class: "hover:underline" %>
      </div>
    </header>

    <div data-drill-target="card">
      <div class="mb-2 flex items-center justify-between text-[11px] tabular-nums text-gray-500 dark:text-gray-400">
        <span data-drill-target="progress"></span>
        <span data-drill-target="score"></span>
      </div>
      <div class="h-1 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-800">
        <div data-drill-target="bar" class="h-full bg-gray-900 transition-all duration-200 dark:bg-gray-100" style="width:0%"></div>
      </div>

      <div class="pt-12 pb-6 text-center">
        <p class="text-[11px] font-semibold uppercase tracking-wide text-gray-400"><%= Translation::LANGUAGES[@from] %></p>
        <p data-drill-target="prompt" class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl"></p>
      </div>

      <input data-drill-target="input" type="text"
             autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false"
             placeholder="<%= Translation::LANGUAGES[@to].downcase %>…"
             class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-center text-xl outline-none focus:border-gray-900 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder-gray-500 dark:focus:border-gray-300">

      <div class="mt-4 min-h-[3.5rem] text-center">
        <span data-drill-target="feedback" class="text-sm"></span>
        <span data-drill-target="answer" class="invisible mt-1 block text-lg font-medium"></span>
        <span data-drill-target="given" class="hidden text-xs text-gray-400"></span>
      </div>

      <p class="mt-6 text-center text-[11px] text-gray-400">
        <span class="font-medium">Enter</span> check · <span class="font-medium">→ ↓ Space Enter</span> next · <span class="font-medium">← ↑</span> back
      </p>
    </div>

    <div data-drill-target="summary" class="hidden pt-12 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400">Done.</p>
      <p data-drill-target="summaryText" class="mt-2 text-3xl font-semibold"></p>
      <p data-drill-target="missed" class="mx-auto mt-3 max-w-md text-xs text-gray-500 dark:text-gray-400"></p>
      <button data-action="drill#restart"
              class="mt-8 rounded-lg border border-gray-300 px-4 py-2 text-sm hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800">
        Again
      </button>
    </div>
  </div>
<% end %>
