<% content_for :title, "#{@title} — drill" %>

<% if @cards.empty? %>
  <div class="text-sm text-gray-500 dark:text-gray-400">
    <p>Nothing to drill here right now<%= " — they're all resting or retired" if defined?(@hide_mastered) && @hide_mastered %>.</p>
    <div class="mt-2 flex flex-wrap gap-3">
      <% if @hide_mastered %>
        <%= link_to "show mastered", play_path(deck: @deck_slug, from: @from, to: @to, hide_mastered: "0"), class: "underline" %>
      <% end %>
      <% if @skip_easy %>
        <%= link_to "show easy cognates", play_path(deck: @deck_slug, from: @from, to: @to, skip_easy: "0"), class: "underline" %>
      <% end %>
      <%= link_to "back to decks", root_path, class: "underline" %>
    </div>
  </div>
<% else %>
  <div data-controller="drill"
       data-drill-cards-value="<%= @cards.to_json %>"
       data-drill-sentences-value="<%= @sentences.to_json %>"
       data-drill-from-value="<%= @from %>"
       data-drill-to-value="<%= @to %>"
       data-drill-multi-value="<%= @multi ? 'true' : 'false' %>"
       data-drill-autoplay-prompt-value="<%= @autoplay_prompt ? 'true' : 'false' %>"
       data-drill-autoplay-wrong-value="<%= @autoplay_wrong ? 'true' : 'false' %>"
       data-drill-correct-feedback-value="<%= current_user.correct_feedback %>"
       data-drill-answer-mode-value="<%= @answer_mode %>"
       data-drill-flow-mode-value="<%= @flow_mode ? 'true' : 'false' %>"
       data-drill-flow-gap-prompt-value="<%= @flow_gap_prompt %>"
       data-drill-flow-gap-next-value="<%= @flow_gap_next %>"
       data-drill-flow-teach-value="<%= @flow_teach ? 'true' : 'false' %>"
       data-drill-record-url-value="<%= attempts_path %>"
       data-drill-ease-url-template-value="<%= ease_term_path('__ID__') %>"
       data-drill-fsrs-enabled-value="<%= ENV['FSRS_ENABLED'] == '1' %>">

    <%# Clean drill top: just the deck name + direction. The cluster of drill
        options (easy cognates / order / mastered / autoplay) now lives in
        Settings (onboarding#show). The brand lockup in the layout nav is the
        page top. A quick ⇄ swap stays inline as a mid-session affordance. %>
    <%# Just the deck name. Direction / swap / options moved entirely to Settings —
        once you've started a group you're going with it; the per-card language
        label already shows which way you're being tested. (Mihai 2026-06-26) %>
    <header class="mb-6">
      <h1 class="text-lg font-semibold"><%= @title %></h1>
    </header>

    <%# "owned" toast — small pill, auto-dismisses (legacy path + FSRS non-retire moments) %>
    <div data-drill-target="celebrate" class="pointer-events-none fixed inset-x-0 top-[calc(env(safe-area-inset-top)+0.75rem)] z-50 hidden justify-center px-4">
      <div class="rounded-full border border-emerald-300 bg-emerald-50 px-5 py-2 text-sm font-medium text-emerald-700 shadow-sm dark:border-emerald-700 dark:bg-emerald-950/60 dark:text-emerald-300">
        <span data-drill-target="celebrateText"></span>
      </div>
    </div>

    <%# FSRS retire overlay — quieter and grander than the "owned" pill.
        Centered card, backdrop blur, emerald border; no confetti.
        Auto-dismisses after 2.8 s; drill flows to next card. (#axis-4) %>
    <div data-drill-target="retireOverlay"
         class="pointer-events-none fixed inset-0 z-50 hidden items-center justify-center bg-white/60 px-6 backdrop-blur-sm dark:bg-gray-950/70">
      <div data-drill-target="retireBubble"
           class="rounded-2xl border border-emerald-300 bg-white px-8 py-6 text-center shadow-sm dark:border-emerald-700 dark:bg-gray-900">
        <p class="text-3xl" aria-hidden="true">🎓</p>
        <p class="mt-2 text-base font-semibold text-emerald-700 dark:text-emerald-300">Retired</p>
        <p class="mt-1 text-lg font-medium dark:text-gray-100" data-drill-target="retireWord"></p>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
          You'll recall this ~6 months out. It's leaving your rotation —
          you've earned the space.
        </p>
      </div>
    </div>

    <p data-drill-target="voiceHint"
       class="mb-4 hidden rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200"></p>

    <%# ── Shared progress bar ── %>
    <div class="mb-2 flex items-center justify-between text-[11px] tabular-nums text-gray-500 dark:text-gray-400">
      <span data-drill-target="progress"></span>
      <span data-drill-target="score"></span>
    </div>
    <div class="h-1 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-800">
      <div data-drill-target="bar" class="h-full bg-brand-indigo transition-all duration-200 dark:bg-brand-sky" style="width:0%"></div>
    </div>

    <% if @multi %>
      <%# ══════════════════════════════════════════════════════════════
          MULTI-LANGUAGE CARD DOM
          Sequential reveal: source word pins; one input live at a time;
          answered languages settle above as a quiet completed band.
      ══════════════════════════════════════════════════════════════ %>
      <div data-drill-target="multiCard">
        <div class="rounded-lg bg-gray-50 px-3 pb-4 pt-3 dark:bg-gray-900/40 mt-4">

          <%# step counter: "1 of 3" — which target within this card %>
          <div class="flex items-center justify-between text-[10px] tabular-nums text-gray-400 dark:text-gray-500">
            <span data-drill-target="multiStep"></span>
            <span class="text-gray-300 dark:text-gray-600"><%= @title %></span>
          </div>

          <%# pinned source word — stays put for the whole card %>
          <div class="pt-5 text-center">
            <p class="text-[10px] font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500"
               data-drill-target="multiFrom"></p>
            <p data-drill-target="multiPrompt"
               class="mt-1 text-3xl font-semibold tracking-tight sm:text-4xl"></p>
            <button type="button" data-action="drill#speakPrompt"
                    class="mt-2 inline-flex min-h-[44px] min-w-[44px] items-center justify-center gap-1 rounded-md px-3 py-2 text-xs text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-800 dark:hover:text-gray-200">
              🔊
            </button>
          </div>

          <%# completed band — answered languages lock in here, quiet %>
          <div data-drill-target="multiDone"
               class="mx-auto mt-5 hidden max-w-xs divide-y divide-gray-100 border-t border-gray-100 pt-1 text-left dark:divide-gray-800 dark:border-gray-800">
          </div>

          <%# live input section — hidden after all targets done %>
          <div data-multi-input-section class="mt-5">
            <p class="text-center text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
               data-drill-target="multiLangLabel"></p>
            <input data-drill-target="multiInput"
                   type="text"
                   <%# Autocorrect ON so iOS helps with typos; autocapitalize off (single
                       vocab words). English keyboard may "fix" foreign words — accepted. %>
                   autocomplete="off" autocapitalize="off" autocorrect="on" spellcheck="true"
                   class="mt-2 w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-center text-lg outline-none focus:border-brand-indigo focus:ring-2 focus:ring-brand-indigo/20 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder-gray-500 dark:focus:border-brand-sky dark:focus:ring-brand-sky/20">
          </div>

          <%# upcoming — faint reminder of remaining languages %>
          <p data-drill-target="multiUpcoming"
             class="mt-3 text-center text-[10px] uppercase tracking-wide text-gray-300 dark:text-gray-600"></p>

          <%# [ETYMOLOGY] insight block, shown once all targets answered %>
          <div data-drill-target="etymology" class="mx-auto mt-4 hidden max-w-sm"></div>

          <%# detail panel: all translations, shown once all targets answered %>
          <div data-drill-target="detail"
               class="mx-auto mt-4 hidden max-w-sm divide-y divide-gray-100 border-t border-gray-100 pt-2 text-left dark:divide-gray-800 dark:border-gray-800"></div>

          <%# action buttons (#fix-3: full-width Next, brand-coral) %>
          <div class="mt-5 flex items-stretch gap-3">
            <button type="button" data-drill-target="backBtn" data-action="drill#prev"
                    aria-label="Previous concept"
                    class="hidden shrink-0 rounded-2xl border border-gray-300 px-5 text-2xl leading-none text-gray-500 transition active:scale-95 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-800">
              ←
            </button>
            <button type="button" data-drill-target="multiCheck" data-action="drill#grade"
                    aria-label="Check answer"
                    class="w-full rounded-2xl bg-brand-indigo px-8 py-5 text-center text-lg font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-indigo/90 dark:bg-brand-indigo dark:text-white dark:hover:bg-brand-indigo/80">
              Check ✓
            </button>
            <button type="button" data-drill-target="multiNext" data-action="drill#next"
                    aria-label="Next concept"
                    class="hidden w-full rounded-2xl bg-brand-coral px-8 py-5 text-center text-xl font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-coral/90">
              Next <span class="ml-2 align-middle text-3xl leading-none">→</span>
            </button>
          </div>

          <p class="mt-5 text-center text-[11px] text-gray-400">
            Tap <span class="font-medium">Next →</span> or <span class="font-medium">swipe →</span> to advance
            <% unless native_app? %><span class="hidden sm:inline">· <span class="font-medium">Enter</span> check · <span class="font-medium">→</span> next · <span class="font-medium">←</span> back</span><% end %>
          </p>
        </div>
      </div>

    <% else %>
      <%# ══════════════════════════════════════════════════════════════
          SINGLE-LANGUAGE CARD DOM (unchanged)
      ══════════════════════════════════════════════════════════════ %>
      <div data-drill-target="card">
        <div class="pt-12 pb-4 text-center">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-gray-400"><%= Translation::LANGUAGES[@from] %><span data-drill-target="kindTag" class="text-amber-500"></span></p>
          <p data-drill-target="prompt" class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl"></p>
          <%# PHONETICS (IPA + translit) with a small replay 🔊 on the SAME line —
              no "hear it" label: in Flow you're already hearing it, this is just a
              manual replay. (Mihai 2026-06-26) %>
          <div class="mt-2 flex items-center justify-center gap-2">
            <div data-drill-target="promptPhonetics"></div>
            <button type="button" data-action="drill#speakPrompt" aria-label="hear it"
                    class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md text-base text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-800 dark:hover:text-gray-200">
              🔊
            </button>
          </div>
        </div>

        <input data-drill-target="input" type="text"
               <%# Autocorrect ON so iOS helps with typos; autocapitalize off (single
                   vocab words). English keyboard may "fix" foreign words — accepted. %>
               autocomplete="off" autocapitalize="off" autocorrect="on" spellcheck="true"
               data-action="focus->drill#onInputFocus"
               placeholder="<%= Translation::LANGUAGES[@to].downcase %>…"
               class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-center text-xl outline-none focus:border-brand-indigo focus:ring-2 focus:ring-brand-indigo/20 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder-gray-500 dark:focus:border-brand-sky dark:focus:ring-brand-sky/20">

        <%# ── Speak mode (answer by voice). Hidden until the JS controller turns
            on speak mode for an answering card; the text input above stays as a
            typing fallback. Not shown in flow/multi modes or where speech
            recognition is unavailable (incl. the iOS WKWebView shell). ── %>
        <div data-drill-target="speakControls" class="mt-3 hidden flex-col items-center gap-2">
          <button type="button" data-drill-target="speakStart" data-action="drill#beginSpeak"
                  class="hidden inline-flex items-center gap-2 rounded-2xl bg-brand-indigo px-6 py-3 text-base font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-indigo/90">
            🎙 Speak
          </button>
          <p data-drill-target="listenStatus" class="text-sm text-gray-500 dark:text-gray-400"></p>
          <p class="text-[11px] text-gray-400 dark:text-gray-500">or type your answer above</p>
        </div>

        <div class="mt-4 min-h-[4.5rem] text-center">
          <span data-drill-target="feedback" class="text-sm"></span>
          <p class="mt-1">
            <span data-drill-target="answer" class="invisible text-lg font-medium align-middle"></span>
            <button type="button" data-drill-target="answerSpeak" data-action="drill#speakAnswer"
                    class="ml-1 hidden h-11 w-11 align-middle rounded-md text-sm text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-gray-800 dark:hover:text-gray-200">
              🔊
            </button>
          </p>
          <%# PHONETICS: IPA + translit under the answer word (populated by drill_controller#renderPhonetics) %>
          <div data-drill-target="answerPhonetics" class="text-center"></div>
          <p data-drill-target="alts" class="text-xs text-gray-500 dark:text-gray-400"></p>
          <p data-drill-target="given" class="hidden text-xs text-gray-400"></p>
          <p data-drill-target="difficulty" class="mt-1 text-[11px] tracking-wide text-gray-400"></p>
          <%# [EASE] mid-drill ease nudge (FSRS only) — populated on reveal by drill_controller#renderEaseNudge %>
          <div data-drill-target="easeNudge" class="mt-2 hidden"></div>
        </div>

        <%# [ETYMOLOGY] Prominent insight block right under the answer — populated by drill_controller#renderEtymology %>
        <div data-drill-target="etymology" class="mx-auto mt-3 hidden max-w-sm"></div>

        <div data-drill-target="detail"
             class="mx-auto mt-3 hidden max-w-sm divide-y divide-gray-100 border-t border-gray-100 pt-2 text-left dark:divide-gray-800 dark:border-gray-800"></div>

        <%# Action row. While answering: a wide Check button. After reveal: a big,
            full-width thumb-friendly Next → button (the obvious "keep going"
            affordance), with a small ← back tucked beside it. (#fix-3) %>
        <div class="mt-6 flex items-stretch gap-3">
          <button type="button" data-drill-target="backBtn" data-action="drill#prev"
                  aria-label="Previous word"
                  class="hidden shrink-0 rounded-2xl border border-gray-300 px-5 text-2xl leading-none text-gray-500 transition active:scale-95 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-800">
            ←
          </button>
          <button type="button" data-drill-target="checkBtn" data-action="drill#grade"
                  aria-label="Check answer"
                  class="hidden w-full rounded-2xl bg-brand-indigo px-8 py-5 text-center text-lg font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-indigo/90 dark:bg-brand-indigo dark:text-white dark:hover:bg-brand-indigo/80">
            Check <span class="ml-2 align-middle">✓</span>
          </button>
          <button type="button" data-drill-target="nextBtn" data-action="drill#next"
                  aria-label="Next word"
                  class="hidden w-full rounded-2xl bg-brand-coral px-8 py-5 text-center text-xl font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-coral/90">
            Next <span class="ml-2 align-middle text-3xl leading-none">→</span>
          </button>
        </div>

        <p data-drill-target="keyHint" class="mt-5 text-center text-[11px] text-gray-400">
          Tap <span class="font-medium">Next →</span> or <span class="font-medium">swipe →</span> to advance
          <% unless native_app? %><span class="hidden sm:inline">· <span class="font-medium">Enter</span> check · <span class="font-medium">→ ↓ Space</span> next · <span class="font-medium">← ↑</span> back</span><% end %>
        </p>

        <%# ── Flow mode controls (hands-free listen). Hidden until the JS
            controller activates flow mode; it then hides the input + Check/Next
            and drives the auto-play loop. ── %>
        <div data-drill-target="flowControls" class="mt-6 hidden flex-col items-center gap-3">
          <button type="button" data-drill-target="flowToggle" data-action="drill#toggleFlow"
                  class="w-full rounded-2xl bg-brand-indigo px-8 py-5 text-center text-lg font-semibold text-white shadow-sm transition active:scale-95 hover:bg-brand-indigo/90">
            Pause
          </button>
          <p class="text-center text-[11px] text-gray-400">
            Flow mode · hands-free ·
            <% unless native_app? %><span class="font-medium">Space</span> pause · <% end %>
            <%= link_to "settings", onboarding_path, class: "underline" %>
          </p>
        </div>
      </div>
    <% end %>

    <%# ── Summary screen (shared) ── %>
    <div data-drill-target="summary" class="hidden pt-12 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400">Done.</p>
      <p data-drill-target="summaryText" class="mt-2 text-3xl font-semibold"></p>
      <p data-drill-target="missed" class="mx-auto mt-3 max-w-md text-xs text-gray-500 dark:text-gray-400"></p>
      <button data-action="drill#restart"
              class="mt-8 rounded-lg border border-gray-300 px-4 py-2 text-sm hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800">
        Again
      </button>
    </div>
  </div>
<% end %>
