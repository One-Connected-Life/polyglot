<!DOCTYPE html>
<html>
  <head>
    <title>App nav prototype — Polyglot</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <%
    s   = (params[:s].presence || "drill")
    sub = params[:sub].presence
    w   = params[:w].presence
    seg = params[:seg].presence

    # SF-symbol-ish icons
    icon = ->(key) {
      {
        words:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M5 4.5A1.5 1.5 0 016.5 3H19v15.5H6.5A1.5 1.5 0 005 20zM5 18.5A1.5 1.5 0 016.5 17H19"/>',
        translate:'<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M4 5h7M7 5c0 4-1.5 8-4 10M5 9c1.5 2.5 4 4 6 4.5M13 20l4-9 4 9M14.5 17h5"/>',
        drill:    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 6.5v11l9-5.5z"/>',
        add:      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5v14M5 12h14"/>',
        settings: '<circle cx="12" cy="12" r="3" stroke-width="1.6"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M19 12a7 7 0 00-.1-1.2l2-1.6-2-3.4-2.4 1a7 7 0 00-2-1.2l-.3-2.6H9.8l-.3 2.6a7 7 0 00-2 1.2l-2.4-1-2 3.4 2 1.6A7 7 0 005 12c0 .4 0 .8.1 1.2l-2 1.6 2 3.4 2.4-1c.6.5 1.3.9 2 1.2l.3 2.6h4.4l.3-2.6c.7-.3 1.4-.7 2-1.2l2.4 1 2-3.4-2-1.6c.1-.4.1-.8.1-1.2z"/>'
      }[key]
    }

    title = { "words" => "My Words", "translate" => "Translate", "drill" => "Drill",
              "add" => "Add", "settings" => "Settings", "word" => (w || "Word") }[s] || "Polyglot"

    # A back link is shown whenever we're deeper than a tab root.
    nested = sub.present? || s == "word"
    parent =
      if s == "word" then "/design/app?s=words&seg=#{seg || 'all'}"
      elsif sub.present? then "/design/app?s=#{s}"
      end
  %>
  <body class="min-h-screen bg-gray-50 pb-28 text-gray-900 dark:bg-neutral-950 dark:text-gray-100">

    <!-- top bar: brand at a tab root, back chevron when nested -->
    <header class="sticky top-0 z-10 flex items-center gap-2 border-b border-gray-200 bg-white/85 px-4 py-3 backdrop-blur dark:border-neutral-800 dark:bg-neutral-900/85">
      <% if nested %>
        <%= link_to parent, class: "flex items-center gap-1 text-brand-indigo dark:text-brand-paper" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5l-7 7 7 7"/></svg>
          <span class="text-sm">Back</span>
        <% end %>
        <span class="ml-1 text-base font-semibold tracking-tight"><%= title %></span>
      <% else %>
        <span class="text-base font-semibold tracking-tight text-brand-indigo dark:text-brand-paper">Poly<span class="text-brand-coral">glot</span></span>
        <span class="ml-1 text-sm text-gray-400">·&nbsp;<%= title %></span>
      <% end %>
    </header>

    <main class="mx-auto max-w-md px-5 py-8">
      <% case s
         when "drill" %>
        <div class="flex flex-col items-center gap-6 pt-10 text-center">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-brand-coral shadow-xl">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-12 w-12 text-white"><%== icon.call(:drill) %></svg>
          </div>
          <div>
            <h1 class="text-2xl font-semibold tracking-tight">Ready to drill</h1>
            <p class="mt-1 text-sm text-gray-500">12 words queued · ~4 min</p>
          </div>
          <span class="rounded-full bg-brand-indigo px-6 py-3 font-medium text-white shadow-lg">Start practice ▸</span>
          <p class="pt-6 text-xs text-gray-400">(stub — the center tab launches this)</p>
        </div>

      <% when "translate" %>
        <%# segmented: Type | Photo %>
        <% mode = seg || "type" %>
        <div class="mb-6 inline-flex w-full rounded-lg border border-gray-200 bg-gray-100 p-0.5 dark:border-neutral-700 dark:bg-neutral-800">
          <% %w[type photo].each do |m| %>
            <%= link_to m.capitalize, "/design/app?s=translate&seg=#{m}",
                  class: "flex-1 rounded-md px-3 py-1.5 text-center text-sm #{mode==m ? 'bg-white font-medium shadow-sm dark:bg-neutral-700' : 'text-gray-500'}" %>
          <% end %>
        </div>
        <% if mode == "type" %>
          <div class="rounded-xl border border-gray-200 p-4 dark:border-neutral-800">
            <p class="text-sm text-gray-400">Type a word or phrase…</p>
            <div class="mt-3 rounded-lg bg-gray-100 px-3 py-2 text-gray-500 dark:bg-neutral-800">gezellig</div>
            <p class="mt-3 text-sm">→ <b>cosy / convivial</b> · 🔊 /xəˈzɛləx/</p>
          </div>
        <% else %>
          <div class="flex aspect-[4/3] items-center justify-center rounded-xl border-2 border-dashed border-gray-300 text-gray-400 dark:border-neutral-700">📷 Snap a sign / page</div>
        <% end %>
        <p class="pt-6 text-center text-xs text-gray-400">(stub · segmented control = the “side-by-side slices” pattern)</p>

      <% when "words" %>
        <% filter = seg || "all"
           words = { "all" => %w[gezellig fiets afspraak lekker borrel],
                     "learning" => %w[afspraak borrel],
                     "retired" => %w[fiets lekker] }[filter] %>
        <div class="mb-5 inline-flex w-full rounded-lg border border-gray-200 bg-gray-100 p-0.5 dark:border-neutral-700 dark:bg-neutral-800">
          <% %w[all learning retired].each do |f| %>
            <%= link_to f.capitalize, "/design/app?s=words&seg=#{f}",
                  class: "flex-1 rounded-md px-3 py-1.5 text-center text-sm #{filter==f ? 'bg-white font-medium shadow-sm dark:bg-neutral-700' : 'text-gray-500'}" %>
          <% end %>
        </div>
        <ul class="divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200 dark:divide-neutral-800 dark:border-neutral-800">
          <% words.each do |word| %>
            <%= link_to "/design/app?s=word&w=#{word}&seg=#{filter}", class: "flex items-center justify-between px-4 py-3 hover:bg-gray-50 dark:hover:bg-neutral-900" do %>
              <span class="font-medium"><%= word %></span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-4 w-4 text-gray-300"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          <% end %>
        </ul>
        <p class="pt-5 text-center text-xs text-gray-400">(tap a word → drills down a level)</p>

      <% when "word" %>
        <div class="space-y-4">
          <h1 class="text-3xl font-semibold tracking-tight"><%= w %></h1>
          <p class="text-gray-500">🔊 /…/ · learning</p>
          <div class="rounded-xl border border-gray-200 p-4 dark:border-neutral-800">
            <p class="text-sm"><b>Meaning.</b> (stub translation + mnemonic + etymology would live here)</p>
          </div>
          <div class="flex gap-2 text-sm">
            <span class="rounded-full bg-gray-100 px-3 py-1 dark:bg-neutral-800">seen 6×</span>
            <span class="rounded-full bg-gray-100 px-3 py-1 dark:bg-neutral-800">due tomorrow</span>
          </div>
          <p class="pt-4 text-xs text-gray-400">(level 3 — drilled down from My Words → ‹ Back returns to the list)</p>
        </div>

      <% when "add" %>
        <% if sub.nil? %>
          <ul class="divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200 dark:divide-neutral-800 dark:border-neutral-800">
            <% [["deck","✨  Generate a deck","From a topic — AI builds a word list"],
                ["audio","🎙️  From audio","Upload a recording → auto-extract vocab"],
                ["paste","📋  Paste a list","Bring your own words"]].each do |key,label,desc| %>
              <%= link_to "/design/app?s=add&sub=#{key}", class: "block px-4 py-4 hover:bg-gray-50 dark:hover:bg-neutral-900" do %>
                <div class="font-medium"><%= label %></div>
                <div class="text-sm text-gray-500"><%= desc %></div>
              <% end %>
            <% end %>
          </ul>
          <p class="pt-5 text-center text-xs text-gray-400">(Add is its own tab now · each row drills down)</p>
        <% else %>
          <div class="rounded-xl border border-gray-200 p-6 text-center dark:border-neutral-800">
            <p class="text-lg font-medium"><%= { "deck"=>"Generate a deck","audio"=>"From audio","paste"=>"Paste a list" }[sub] %></p>
            <p class="mt-2 text-sm text-gray-500">(stub sub-screen — ‹ Back returns to Add)</p>
          </div>
        <% end %>

      <% when "settings" %>
        <% if sub.nil? %>
          <ul class="divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200 dark:divide-neutral-800 dark:border-neutral-800">
            <% [["account","Account"],["languages","Languages"],["direction","Drill direction"],["notifications","Notifications"]].each do |key,label| %>
              <%= link_to "/design/app?s=settings&sub=#{key}", class: "flex items-center justify-between px-4 py-3 hover:bg-gray-50 dark:hover:bg-neutral-900" do %>
                <span><%= label %></span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-4 w-4 text-gray-300"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            <% end %>
          </ul>
          <div class="mt-4 text-center"><span class="text-sm text-brand-coral">Sign out</span></div>
          <p class="pt-5 text-center text-xs text-gray-400">(classic drill-down list — like iOS Settings)</p>
        <% else %>
          <div class="rounded-xl border border-gray-200 p-6 text-center dark:border-neutral-800">
            <p class="text-lg font-medium"><%= sub.capitalize %></p>
            <p class="mt-2 text-sm text-gray-500">(stub sub-screen — ‹ Back returns to Settings)</p>
          </div>
        <% end %>
      <% end %>
    </main>

    <!-- bottom 5-tab bar; center = raised Drill CTA -->
    <nav class="fixed inset-x-0 bottom-0 z-20 border-t border-gray-200 bg-white/90 backdrop-blur dark:border-neutral-800 dark:bg-neutral-900/90" style="padding-bottom: env(safe-area-inset-bottom);">
      <div class="mx-auto flex max-w-md items-end justify-around px-2 pt-2">
        <%
          tabs = [["words","My Words"],["translate","Translate"],["drill","Drill"],["add","Add"],["settings","Settings"]]
          tabs.each do |key,label|
            active = (s == key) || (key == "words" && s == "word")
            color  = active ? "text-brand-indigo dark:text-brand-paper" : "text-gray-400 dark:text-gray-500"
        %>
          <% if key == "drill" %>
            <%= link_to "/design/app?s=drill", class: "flex flex-1 flex-col items-center" do %>
              <span class="-mt-6 flex h-14 w-14 items-center justify-center rounded-full bg-brand-coral shadow-lg ring-4 ring-white dark:ring-neutral-900">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-7 w-7 text-white"><%== icon.call(:drill) %></svg>
              </span>
              <span class="mt-1 text-[10px] font-semibold tracking-tight <%= color %>"><%= label %></span>
            <% end %>
          <% else %>
            <%= link_to "/design/app?s=#{key}", class: "flex flex-1 flex-col items-center gap-1 pb-1 #{color}" do %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-6 w-6"><%== icon.call(key.to_sym) %></svg>
              <span class="text-[10px] font-medium tracking-tight"><%= label %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </nav>
  </body>
</html>
