<% content_for :title, "What are you learning?" %>

<div class="mx-auto max-w-sm">
  <h1 class="text-2xl font-semibold tracking-tight">What do you want to learn?</h1>
  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">You can change this anytime in settings.</p>

  <% if @user.errors.any? %>
    <ul class="mt-4 space-y-1 rounded-md border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-800 dark:bg-rose-950/40 dark:text-rose-300">
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with model: @user, url: onboarding_path, method: :patch, class: "mt-6 space-y-5" do |f| %>
    <% if @user.name.blank? %>
      <div>
        <%= f.label :name, "Your name", class: "block text-xs font-medium text-gray-600 dark:text-gray-300" %>
        <%= f.text_field :name, autocomplete: "name", class: "mt-1 #{field_classes}" %>
      </div>
    <% end %>

    <div>
      <%= f.label :source_language, "I already speak", class: "block text-xs font-medium text-gray-600 dark:text-gray-300" %>
      <%= f.select :source_language, options_for_select(language_options, @user.source_language || "en"), {}, class: "mt-1 #{field_classes}" %>
    </div>

    <%# Multi-select chip picker for learning languages.
        Hidden sentinel ensures the param key always arrives even when nothing is checked.
        JS controller (language-chips) toggles the visual selected/unselected state. %>
    <div data-controller="language-chips">
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-300">I'm learning</label>
      <p class="mt-0.5 text-[11px] text-gray-400 dark:text-gray-500">Tap to add. Drill any of these together or one at a time.</p>

      <%# sentinel so the key always arrives %>
      <input type="hidden" name="user[learning_languages][]" value="">

      <div class="mt-2 flex flex-wrap gap-2">
        <% source = @user.source_language || "en" %>
        <% selected_langs = @user.active_learning_languages %>
        <% Translation::LANGUAGES.each do |code, name| %>
          <% next if code == source %>
          <% is_selected = selected_langs.include?(code) %>
          <label class="cursor-pointer">
            <input type="checkbox" name="user[learning_languages][]" value="<%= code %>"
                   <%= "checked" if is_selected %>
                   class="sr-only"
                   data-language-chips-target="checkbox"
                   data-action="change->language-chips#toggle">
            <span data-language-chips-target="chip"
                  class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium transition-colors
                         <%= is_selected ? 'border-gray-900 bg-gray-900 text-white dark:border-gray-100 dark:bg-gray-100 dark:text-gray-900' : 'border-gray-300 text-gray-500 dark:border-gray-700 dark:text-gray-400' %>">
              <%= name %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%# Drill direction (forward=source→targets, random=any order per card) %>
    <div>
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-300">Drill direction</label>
      <div class="mt-1.5 inline-flex rounded-lg border border-gray-300 bg-gray-50 p-0.5 dark:border-gray-700 dark:bg-gray-950">
        <% [["forward", "Source → target"], ["random", "Randomize order"]].each do |value, label| %>
          <label class="cursor-pointer">
            <%= f.radio_button :drill_direction, value,
                  class: "sr-only",
                  data: { action: "change->language-chips#noop" } %>
            <span class="block rounded-md px-3 py-1.5 text-sm transition-colors
                         <%= @user.drill_direction == value ? 'bg-white shadow-sm dark:bg-gray-700 text-gray-900 dark:text-gray-100' : 'text-gray-500 dark:text-gray-400' %>">
              <%= label %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%# ── Drill options (Finding A) ───────────────────────────────────────────
        Relocated here from the drill play screen so the drill top stays clean.
        Persisted per-user; every option still works, just from Settings. %>
    <div class="border-t border-gray-200 pt-5 dark:border-gray-800">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200">Drill options</h2>
      <p class="mt-0.5 text-[11px] text-gray-400 dark:text-gray-500">How drills behave. Applies the next time you start one.</p>

      <%# Default direction: recall-first (target→source, e.g. NL→EN, easier
          recognition — the default) vs production (source→target, harder).
          This is the durable preference /play respects when you start a drill;
          the per-session ⇄ swap can still flip it for one session. %>
      <% src = @user.source_language_name || (@user.source_language || "EN").upcase %>
      <% tgt = @user.target_language_name || (@user.target_language || "").upcase %>
      <% if @user.target_language.present? %>
        <div class="mt-4">
          <label class="block text-xs font-medium text-gray-600 dark:text-gray-300">Default direction</label>
          <div class="mt-1.5 inline-flex rounded-lg border border-gray-300 bg-gray-50 p-0.5 dark:border-gray-700 dark:bg-gray-950">
            <% [["true", "#{tgt} → #{src}"], ["false", "#{src} → #{tgt}"]].each do |value, label| %>
              <label class="cursor-pointer">
                <%= f.radio_button :drill_recall_first, value, class: "sr-only" %>
                <span class="block rounded-md px-3 py-1.5 text-sm transition-colors
                             <%= @user.drill_recall_first?.to_s == value ? 'bg-white shadow-sm dark:bg-gray-700 text-gray-900 dark:text-gray-100' : 'text-gray-500 dark:text-gray-400' %>">
                  <%= label %>
                </span>
              </label>
            <% end %>
          </div>
          <p class="mt-1 text-[11px] text-gray-400 dark:text-gray-500"><%= tgt %> → <%= src %> recalls the word you know (easier). Flip it to practice producing <%= tgt %>.</p>
        </div>
      <% end %>

      <%# Order: smart (FSRS) vs shuffle (random) %>
      <div class="mt-4">
        <label class="block text-xs font-medium text-gray-600 dark:text-gray-300">Order</label>
        <div class="mt-1.5 inline-flex rounded-lg border border-gray-300 bg-gray-50 p-0.5 dark:border-gray-700 dark:bg-gray-950">
          <% [["smart", "Smart"], ["shuffle", "Shuffle"]].each do |value, label| %>
            <label class="cursor-pointer">
              <%= f.radio_button :drill_order, value, class: "sr-only" %>
              <span class="block rounded-md px-3 py-1.5 text-sm transition-colors
                           <%= @user.drill_order == value ? 'bg-white shadow-sm dark:bg-gray-700 text-gray-900 dark:text-gray-100' : 'text-gray-500 dark:text-gray-400' %>">
                <%= label %>
              </span>
            </label>
          <% end %>
        </div>
        <p class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">Smart = spaced-repetition order. Shuffle = fully random.</p>
      </div>

      <%# Toggle checkboxes. Hidden sentinel before each so an unchecked box still
          posts "0" (Rails check_box does this automatically via its hidden field). %>
      <div class="mt-4 space-y-3">
        <%# Show other languages — opt-in multi-language "weave" (default OFF →
            single-language). Only meaningful with 2+ learning languages; shown
            always so the choice is discoverable, but noted as needing more langs. %>
        <label class="flex cursor-pointer items-start gap-2.5">
          <%= f.check_box :show_other_languages, class: "mt-0.5 h-4 w-4 rounded accent-brand-coral" %>
          <span class="text-sm">
            Show other languages
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">
              Weave all the languages you're learning into one card.
              <% unless @user.multi_language_drill? %>Add a second learning language above to use this.<% else %>Off = a clean single-language card (recommended).<% end %>
            </span>
          </span>
        </label>

        <%# skip_easy + hide_mastered are superseded by FSRS (auto-skips cognates,
            retires mastered). When FSRS is live we grey them out + explain, rather
            than show dead controls. include_hidden:false so a disabled box doesn't
            clobber the stored value on save. %>
        <label class="flex items-start gap-2.5 <%= fsrs_enabled? ? 'opacity-50' : 'cursor-pointer' %>">
          <%= f.check_box :skip_easy, class: "mt-0.5 h-4 w-4 rounded accent-brand-indigo", disabled: fsrs_enabled?, include_hidden: !fsrs_enabled? %>
          <span class="text-sm">
            Hide easy cognates
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">
              <% if fsrs_enabled? %>Handled automatically — the spaced-repetition engine already skips easy cognates.<% else %>Skip words that look almost identical in both languages.<% end %>
            </span>
          </span>
        </label>

        <label class="flex items-start gap-2.5 <%= fsrs_enabled? ? 'opacity-50' : 'cursor-pointer' %>">
          <%= f.check_box :hide_mastered, class: "mt-0.5 h-4 w-4 rounded accent-brand-indigo", disabled: fsrs_enabled?, include_hidden: !fsrs_enabled? %>
          <span class="text-sm">
            Rest mastered words
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">
              <% if fsrs_enabled? %>Handled automatically — the spaced-repetition engine rests and retires mastered words.<% else %>Hide words you've recently mastered so they rest before returning.<% end %>
            </span>
          </span>
        </label>

        <label class="flex cursor-pointer items-start gap-2.5">
          <%= f.check_box :autoplay_prompt, class: "mt-0.5 h-4 w-4 rounded accent-brand-indigo" %>
          <span class="text-sm">
            🔊 Auto-play prompt
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">Speak each word aloud as it appears.</span>
          </span>
        </label>

        <label class="flex cursor-pointer items-start gap-2.5">
          <%= f.check_box :autoplay_wrong, class: "mt-0.5 h-4 w-4 rounded accent-brand-indigo" %>
          <span class="text-sm">
            🔊 Read answer if wrong
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">Speak the correct answer aloud when you miss.</span>
          </span>
        </label>

        <label class="flex cursor-pointer items-start gap-2.5">
          <%= f.check_box :drill_sentences, class: "mt-0.5 h-4 w-4 rounded accent-brand-indigo" %>
          <span class="text-sm">
            Interleave sentences
            <span class="block text-[11px] text-gray-400 dark:text-gray-500">Sprinkle short example sentences (built from words you've practiced) between word cards. Turn off for words only.</span>
          </span>
        </label>
      </div>
    </div>

    <%= f.submit "Save & start drilling", class: primary_button_classes %>
  <% end %>
</div>
