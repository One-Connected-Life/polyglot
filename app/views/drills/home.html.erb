<% content_for :title, "#{current_user.target_language_name} drill" %>
<% target = current_user.target_language %>
<% source = current_user.source_language %>
<% learning = current_user.active_learning_languages %>
<% generating   = @decks.select { |d| d.status == "pending" } %>
<% transcribing = @decks.select { |d| d.status == "transcribing" } %>
<% expanding    = @decks.select(&:expanding?) %>
<% reviewable   = @decks.select(&:needs_review?) %>
<% working      = generating.any? || transcribing.any? || expanding.any? %>

<%# Gentle poll while a deck generates or transcribes — Turbo replace-visit, not a hard
    meta refresh (keeps scroll position, no white flash on the phone). %>
<% if working %>
  <div data-controller="poll" data-poll-interval-value="5000" class="hidden"></div>
<% end %>

<header class="mb-10 flex items-end justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight"><%= current_user.target_language_name %> drill</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Your vocabulary, your pace.</p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "Your words →", stats_path, class: "shrink-0 text-xs text-gray-500 hover:underline dark:text-gray-400" %>
    <%= link_to "Settings", onboarding_path, class: "shrink-0 text-xs text-gray-500 hover:underline dark:text-gray-400" %>
  </div>
</header>

<%= render "drills/translate_box" %>

<% if generating.any? %>
  <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
    ⏳ Generating <%= generating.map(&:name).to_sentence %>… this page refreshes itself.
  </div>
<% end %>

<% if transcribing.any? %>
  <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
    🎧 Transcribing <%= transcribing.map(&:name).to_sentence %>… this page refreshes itself.
  </div>
<% end %>

<% if expanding.any? %>
  <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-950/30 dark:text-amber-200">
    ➕ Adding words to <%= expanding.map(&:name).to_sentence %>… this page refreshes itself.
  </div>
<% end %>

<% reviewable.each do |deck| %>
  <div class="mb-4 flex items-center justify-between gap-4 rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-200">
    <span>✨ “<%= deck.name %>” is ready to review — <%= pluralize(deck.pending_review_count, "word") %>.</span>
    <%= link_to "Review →", review_deck_path(deck),
          class: "shrink-0 rounded-md border border-emerald-400 px-2.5 py-1 font-medium hover:bg-emerald-100 dark:border-emerald-700 dark:hover:bg-emerald-900/40" %>
  </div>
<% end %>

<% failed = @decks.select { |d| d.status == "failed" } %>
<% if failed.any? %>
  <div class="mb-6 rounded-lg border border-rose-300 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-800 dark:bg-rose-950/30 dark:text-rose-300">
    <p>Couldn't build <%= failed.map(&:name).to_sentence %><% if (detail = failed.filter_map(&:status_detail).first).present? %> — <%= detail %><% else %> — the generator errored<% end %>. Try
      <%= link_to "a different topic", new_deck_path, class: "underline" %> or
      <%= link_to "another recording", new_audio_deck_path, class: "underline" %>.</p>
    <div class="mt-2 flex flex-wrap gap-2">
      <% failed.each do |d| %>
        <%= button_to "Remove #{d.name}", deck_path(d), method: :delete,
              class: "rounded border border-rose-300 px-2 py-0.5 text-xs hover:bg-rose-100 dark:border-rose-700 dark:hover:bg-rose-900/40" %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @word_count.zero? && !working && reviewable.none? %>
  <div class="rounded-lg border border-gray-300 bg-white px-5 py-6 text-center dark:border-gray-700 dark:bg-gray-900">
    <p class="text-sm text-gray-600 dark:text-gray-300">No words yet.</p>
    <p class="mx-auto mt-1 max-w-sm text-xs text-gray-500 dark:text-gray-400">
      Pick a topic, or upload audio you want to understand — we'll build a
      <%= current_user.target_language_name %> deck from it.
    </p>
    <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
      <%= link_to "Create your first deck", new_deck_path,
            class: "inline-block rounded-lg bg-brand-indigo px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-brand-indigo/90" %>
      <%= link_to "Upload audio", new_audio_deck_path,
            class: "inline-block rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
    </div>
  </div>
<% elsif @word_count.positive? %>
  <% if @miss_counts.any? %>
    <div class="mb-4 flex items-center justify-between gap-4 rounded-lg border border-gray-200 border-l-4 border-l-rose-400 bg-white px-4 py-4 dark:border-gray-700 dark:border-l-rose-400 dark:bg-gray-900">
      <div>
        <span class="text-base font-semibold">Your misses</span>
        <p class="text-xs text-gray-500 dark:text-gray-400">words you got wrong last time — get them right to clear them</p>
      </div>
      <div class="flex items-center gap-2 text-xs">
        <% @miss_counts.each do |(from, to), count| %>
          <%= link_to "#{from.upcase} → #{to.upcase} (#{count})", play_path(deck: "misses", from: from, to: to),
                class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── All words row: single-language + optional multi-language ── %>
  <div class="mb-8 flex items-center justify-between gap-4 rounded-lg border border-gray-300 bg-white px-4 py-4 dark:border-gray-700 dark:bg-gray-900">
    <div>
      <%= link_to "All words", play_path(deck: "all", from: source, to: target), class: "text-base font-semibold hover:underline" %>
      <p class="text-xs text-gray-500 dark:text-gray-400">every word, shuffled · <%= pluralize(@word_count, "word") %></p>
    </div>
    <div class="flex flex-wrap items-center justify-end gap-2 text-xs">
      <%= link_to "#{source.upcase} → #{target.upcase}", play_path(deck: "all", from: source, to: target),
            class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
      <%= link_to "#{target.upcase} → #{source.upcase}", play_path(deck: "all", from: target, to: source),
            class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
      <%# Multi-language entry point: only shown when the user has 2+ learning languages %>
      <% if current_user.multi_language_drill? %>
        <%= link_to "#{source.upcase} → all #{learning.size}", play_path(deck: "all", from: source, multi: "1"),
              class: "rounded-md border border-brand-coral bg-brand-coral px-2.5 py-1 font-medium text-white shadow-sm hover:bg-brand-coral/90" %>
      <% end %>
    </div>
  </div>

  <%# ── Basics: All — one drill across the whole foundation (pronouns…verbs…numbers) ── %>
  <% if @basics_count.to_i > 0 %>
    <div class="mb-8 flex items-center justify-between gap-4 rounded-lg border border-gray-300 bg-white px-4 py-4 dark:border-gray-700 dark:bg-gray-900">
      <div>
        <%= link_to "Basics: All", play_path(deck: "basics", from: target, to: source), class: "text-base font-semibold hover:underline" %>
        <p class="text-xs text-gray-500 dark:text-gray-400">the whole foundation, shuffled · <%= pluralize(@basics_count, "card") %></p>
      </div>
      <div class="flex flex-wrap items-center justify-end gap-2 text-xs">
        <%= link_to "#{source.upcase} → #{target.upcase}", play_path(deck: "basics", from: source, to: target),
              class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
        <%= link_to "#{target.upcase} → #{source.upcase}", play_path(deck: "basics", from: target, to: source),
              class: "rounded-md border border-gray-300 px-2.5 py-1 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
        <% if current_user.multi_language_drill? %>
          <%= link_to "#{source.upcase} → all #{learning.size}", play_path(deck: "basics", from: source, multi: "1"),
                class: "rounded-md border border-brand-coral bg-brand-coral px-2.5 py-1 font-medium text-white shadow-sm hover:bg-brand-coral/90" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mb-3 flex items-center justify-between">
    <p class="text-xs uppercase tracking-wide text-gray-400">your decks</p>
    <div class="flex items-center gap-3">
      <%= link_to "+ add a topic", new_deck_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
      <%= link_to "↑ from audio", new_audio_deck_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
    </div>
  </div>

  <% ready_decks = @decks.select { |d| d.status == "ready" && d.terms.any?(&:reviewed) } %>
  <% th = "px-3 py-2 text-left font-semibold cursor-pointer select-none whitespace-nowrap hover:bg-gray-100 dark:hover:bg-gray-800" %>
  <div data-controller="sortable-table" class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="border-y border-gray-400 bg-gray-50 text-xs uppercase tracking-wide text-gray-600 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300">
          <th class="<%= th %>" data-action="click->sortable-table#sort" data-col="0" data-sort-type="string">Deck<span data-arrow></span></th>
          <th class="<%= th %> text-right" data-action="click->sortable-table#sort" data-col="1" data-sort-type="number">Words<span data-arrow></span></th>
          <th class="<%= th %>" data-action="click->sortable-table#sort" data-col="2" data-sort-type="number">Added<span data-arrow></span></th>
          <th class="px-3 py-2 text-right font-semibold whitespace-nowrap">Drill</th>
        </tr>
      </thead>
      <tbody data-sortable-table-target="body">
        <% ready_decks.each do |deck| %>
          <% unit = deck.terms.exists?(kind: "sentence") ? "sentence" : "word" %>
          <tr class="border-b border-gray-200 odd:bg-white even:bg-gray-50 dark:border-gray-800 dark:odd:bg-gray-900 dark:even:bg-gray-800/40">
            <td class="max-w-[20rem] px-3 py-1.5">
              <%= link_to deck.name, play_path(deck: deck.slug, from: target, to: source),
                    class: "block truncate font-medium hover:underline", title: ([deck.name, deck.topic.presence].compact.join(" · ")) %>
            </td>
            <td class="px-3 py-1.5 text-right tabular-nums text-gray-600 dark:text-gray-400"><%= deck.terms.count(&:reviewed) %></td>
            <td class="px-3 py-1.5 whitespace-nowrap text-gray-500 dark:text-gray-400" data-sort-value="<%= deck.created_at.to_i %>" title="<%= deck.created_at.strftime("%-d %b %Y, %H:%M") %>"><%= deck.created_at.strftime("%-d %b %y") %></td>
            <td class="px-3 py-1.5">
              <div class="flex items-center justify-end gap-1.5 text-xs">
                <% if deck.topic.present? %>
                  <%= button_to "+ words", expand_deck_path(deck), method: :post,
                        class: "rounded-md border border-emerald-400 px-2 py-0.5 text-emerald-700 hover:bg-emerald-50 dark:border-emerald-700 dark:text-emerald-300 dark:hover:bg-emerald-900/30",
                        form: { data: { turbo_confirm: "Add a fresh batch of “#{deck.name}” words to review?" } },
                        title: "Generate more words for this topic" %>
                <% end %>
                <%= link_to "#{target.upcase}→#{source.upcase}", play_path(deck: deck.slug, from: target, to: source),
                      class: "rounded-md border border-gray-300 px-2 py-0.5 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
                <%= link_to "#{source.upcase}→#{target.upcase}", play_path(deck: deck.slug, from: source, to: target),
                      class: "rounded-md border border-gray-300 px-2 py-0.5 hover:bg-gray-100 dark:border-gray-700 dark:hover:bg-gray-800" %>
                <% if current_user.multi_language_drill? %>
                  <%= link_to "→all #{learning.size}", play_path(deck: deck.slug, from: source, multi: "1"),
                        class: "rounded-md border border-brand-coral bg-brand-coral px-2 py-0.5 font-medium text-white hover:bg-brand-coral/90" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
