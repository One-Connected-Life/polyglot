<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Polyglot" %></title>
    <%# viewport-fit=cover is REQUIRED for env(safe-area-inset-*) to resolve on
        notched/Dynamic-Island iPhones — without it every safe-area inset is 0. %>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Polyglot">
    <%# black-translucent lets the dark body bg show behind the status bar / Island. %>
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Polyglot">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16">
    <link rel="icon" href="/icon.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# min-h-dvh (not vh) tracks Safari's dynamic toolbar so bottom content isn't
      hidden. Safe-area padding keeps nav/content clear of the Dynamic Island and
      home indicator; border-box (Tailwind preflight) folds the padding into the
      dvh height so there's no overflow scroll. %>
  <body class="min-h-dvh bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)]">
    <% if current_user %>
      <nav class="border-b border-gray-200 bg-white/70 backdrop-blur dark:border-gray-800 dark:bg-gray-950/70">
        <div class="mx-auto flex max-w-2xl items-center justify-between px-5 py-2.5">
          <%= link_to root_path, class: "flex items-center gap-2 group", "aria-label": "Polyglot — drill" do %>
            <%= image_tag "polyglot-mark.svg", alt: "", width: 24, height: 24,
                  class: "h-6 w-6 rounded-md shadow-sm transition group-hover:scale-105" %>
            <span class="text-base font-semibold tracking-tight text-brand-indigo dark:text-brand-paper">
              Poly<span class="text-brand-coral">glot</span>
            </span>
            <%# Build tag — only present inside a native shell (UA token); plain
                browsers see nothing. Tiny + muted so it never competes with the
                wordmark. %>
            <% if (tag = app_build_tag) %>
              <span class="text-xs font-medium text-gray-400 dark:text-gray-500" title="Native build <%= tag %>"><%= tag %></span>
            <% end %>
          <% end %>
          <div class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-400">
            <%= link_to "Your words", stats_path, class: "hover:text-brand-indigo hover:underline dark:hover:text-brand-paper" %>
            <%# Settings wheel — reachable on every page, opens the Settings page. %>
            <%= link_to onboarding_path, class: "text-gray-500 transition hover:rotate-45 hover:text-brand-indigo dark:text-gray-400 dark:hover:text-brand-paper", title: "Settings", "aria-label": "Settings" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>
    <% if notice || alert %>
      <div class="mx-auto max-w-2xl px-5 pt-4">
        <% if notice %>
          <p class="rounded-md border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950/40 dark:text-emerald-300"><%= notice %></p>
        <% end %>
        <% if alert %>
          <p class="rounded-md border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700 dark:border-rose-800 dark:bg-rose-950/40 dark:text-rose-300"><%= alert %></p>
        <% end %>
      </div>
    <% end %>
    <main class="mx-auto max-w-2xl px-5 py-10 sm:py-16">
      <%= yield %>
    </main>
  </body>
</html>
