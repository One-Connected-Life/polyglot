<%#
  One frozen frame of the concept card (#multilang mock).
  locals: step_label, done [{name, answer, ok, correct?}], current {name, placeholder}|nil,
          input_value, input_state (:empty|:ready|:done), upcoming [names], caption
%>
<figure class="rounded-xl border border-gray-200 p-4 dark:border-gray-800">
  <div class="rounded-lg bg-gray-50 px-3 pb-4 pt-3 dark:bg-gray-900/40">

    <%# progress: which language of the concept, not a percentage bar %>
    <div class="flex items-center justify-between text-[10px] tabular-nums text-gray-400 dark:text-gray-500">
      <span><%= step_label %></span>
      <span>concept 7 / 42</span>
    </div>

    <%# pinned concept: the source word stays put for the whole card %>
    <div class="pt-5 text-center">
      <p class="text-[10px] font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">English</p>
      <p class="mt-1 text-3xl font-semibold tracking-tight">bread</p>
    </div>

    <%# completed band: languages already answered, settled and quiet %>
    <% if done.any? %>
      <div class="mx-auto mt-5 max-w-xs divide-y divide-gray-100 border-t border-gray-100 pt-1 text-left dark:divide-gray-800 dark:border-gray-800">
        <% done.each do |d| %>
          <div class="flex items-baseline justify-between py-1">
            <span class="text-[11px] uppercase tracking-wide text-gray-400 dark:text-gray-500"><%= d[:name] %></span>
            <span class="flex items-baseline gap-1.5 text-sm">
              <% if d[:ok] %>
                <span class="text-emerald-600 dark:text-emerald-400">✓</span>
                <span><%= d[:answer] %></span>
              <% else %>
                <span class="text-rose-500 dark:text-rose-400">✗</span>
                <span class="text-gray-400 line-through dark:text-gray-500"><%= d[:answer] %></span>
                <span class="font-medium"><%= d[:correct] %></span>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# live input: the one language being asked right now %>
    <% if current %>
      <div class="mt-5">
        <p class="text-center text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"><%= current[:name] %></p>
        <div class="mt-2 w-full rounded-lg border bg-white px-4 py-2.5 text-center text-lg dark:bg-gray-900
                    <%= input_state == :ready ? 'border-gray-900 dark:border-gray-300' : 'border-gray-300 dark:border-gray-700' %>">
          <% if input_value %>
            <span class="text-gray-900 dark:text-gray-100"><%= input_value %></span><span class="text-gray-400">|</span>
          <% else %>
            <span class="text-gray-400 dark:text-gray-500"><%= current[:placeholder] %></span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# upcoming: faint markers so you see how many languages remain on this card %>
    <% if upcoming.any? %>
      <p class="mt-3 text-center text-[10px] uppercase tracking-wide text-gray-300 dark:text-gray-600">
        then <%= upcoming.join(" · ") %>
      </p>
    <% end %>

    <%# action: one primary button, mirrors the live drill %>
    <div class="mt-5 flex justify-center">
      <% if input_state == :done %>
        <span class="rounded-xl bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white dark:bg-gray-100 dark:text-gray-900">Next concept →</span>
      <% elsif input_state == :ready %>
        <span class="rounded-xl bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white dark:bg-gray-100 dark:text-gray-900">Check ✓</span>
      <% else %>
        <span class="rounded-xl border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-400 dark:border-gray-700 dark:text-gray-500">Check ✓</span>
      <% end %>
    </div>
  </div>

  <figcaption class="mt-2 text-center text-[11px] text-gray-400 dark:text-gray-500"><%= caption %></figcaption>
</figure>
