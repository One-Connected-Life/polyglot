<% content_for :title, "Translation" %>
<% target_name = current_user.target_language_name %>
<% source_name = current_user.source_language_name %>
<% non_latin = Translation::NON_LATIN.include?(current_user.target_language) %>

<div>
  <%= link_to "← translate something else", root_path,
        class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>

  <% if @captured %>
    <div class="mt-3 flex items-center justify-between gap-4 rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-200">
      <span>✨ Captured <%= pluralize(@words.size, "word") %> to <strong>My Words</strong>.</span>
      <%= link_to "Drill →", play_path(deck: @deck.slug, from: current_user.target_language, to: current_user.source_language),
            class: "shrink-0 rounded-md border border-emerald-400 px-2.5 py-1 font-medium hover:bg-emerald-100 dark:border-emerald-700 dark:hover:bg-emerald-900/40" %>
    </div>
  <% end %>

  <h1 class="mt-4 text-2xl font-semibold tracking-tight">
    <%= target_name %> → <%= source_name %>
  </h1>
  <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
    <%= pluralize(@words.size, "word") %><% unless @captured %> · not captured<% end %>
  </p>

  <ul class="mt-6 space-y-2">
    <% @words.each do |w| %>
      <% article = w["article"].to_s.strip.presence %>
      <% display = [article, w["target"].to_s.strip].compact.join(article&.end_with?("'") ? "" : " ") %>
      <li class="rounded-lg border border-gray-200 bg-white p-3 dark:border-gray-800 dark:bg-gray-900">
        <div class="flex items-baseline justify-between gap-3">
          <span class="text-lg font-medium"><%= display %></span>
          <span class="text-right text-gray-600 dark:text-gray-300"><%= w["source"] %></span>
        </div>
        <% ipa = w["ipa"].to_s.strip.presence %>
        <% translit = (non_latin ? w["translit"].to_s.strip.presence : nil) %>
        <% if ipa || translit || w["etymology"].to_s.strip.presence %>
          <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
            <% if ipa %><span class="font-mono">/<%= ipa %>/</span><% end %>
            <% if translit %><span><%= " · " if ipa %><%= translit %></span><% end %>
            <% if w["etymology"].to_s.strip.presence %><span><%= " · " if ipa || translit %><%= w["etymology"] %></span><% end %>
          </p>
        <% end %>
      </li>
    <% end %>
  </ul>

  <% unless @captured %>
    <div class="mt-6">
      <%= form_with url: translate_path, method: :post, data: { turbo: false } do |f| %>
        <%= hidden_field_tag :text, @words.map { |w| [w["article"], w["target"]].compact.join(" ") }.join("\n") %>
        <%= hidden_field_tag :capture, "1" %>
        <%= f.submit "Capture these to My Words",
              class: "w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
      <% end %>
    </div>
  <% end %>
</div>
